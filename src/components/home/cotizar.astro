---
// CotizadorEmbed.astro
// Uso: <CotizadorEmbed />
---

<section class="cotizador-section">
  <div class="header">
    <span class="eyebrow">AL Mundo Tours by Amanve</span>
    <h2>Personaliza tu <span>viaje</span></h2>
    <p>
      Cotiza en minutos. Elige destino, hotel, vuelos y extras,
      y recibe tu cotización al instante.
    </p>
    <div class="divider"></div>
  </div>

  <div class="iframe-wrapper">
    <iframe
      src="https://almundo-cotizador.vercel.app/cotizar"
      title="Cotizador de viajes AL Mundo Tours"
      allow="clipboard-write"
      loading="lazy"
    ></iframe>
  </div>

  <p class="footer">
    Powered by <a href="https://almundo-cotizador.vercel.app" target="_blank" rel="noopener">AL Mundo Tours by Amanve</a>
  </p>
</section>

<style>
  .cotizador-section {
    width: 100%;
    background: #ffffff;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 64px 20px;
  }

  /* Encabezado */
  .header {
    text-align: center;
    max-width: 640px;
    width: 100%;
    margin-bottom: 36px;
  }

  .eyebrow {
    display: inline-block;
    background: #ede9fe;
    color: #6d28d9;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    padding: 6px 16px;
    border-radius: 100px;
    margin-bottom: 18px;
  }

  h2 {
    font-size: clamp(26px, 5vw, 40px);
    font-weight: 900;
    color: #1e293b;
    line-height: 1.15;
    margin-bottom: 12px;
  }

  h2 span {
    color: #6d28d9;
  }

  .header p {
    font-size: 15px;
    color: #64748b;
    line-height: 1.7;
    max-width: 460px;
    margin: 0 auto;
  }

  .divider {
    width: 48px;
    height: 4px;
    background: linear-gradient(90deg, #7c3aed, #6d28d9);
    border-radius: 4px;
    margin: 20px auto 0;
  }

  /* Iframe */
  .iframe-wrapper {
    width: 100%;
    max-width: 760px;
    background: #fff;
    border-radius: 20px;
    box-shadow:
      0 4px 6px rgba(0, 0, 0, 0.04),
      0 20px 60px rgba(109, 40, 217, 0.10);
    overflow: hidden;
    border: 1px solid #ede9fe;
  }

  .iframe-wrapper iframe {
    width: 100%;
    height: 860px;
    border: none;
    display: block;
  }

  /* Footer */
  .footer {
    margin-top: 20px;
    font-size: 12px;
    color: #94a3b8;
    text-align: center;
  }

  .footer a {
    color: #6d28d9;
    text-decoration: none;
    font-weight: 600;
  }

  .footer a:hover {
    text-decoration: underline;
  }

  /* Responsive */
  @media (max-width: 600px) {
    .cotizador-section {
      padding: 40px 12px;
    }

    .iframe-wrapper iframe {
      height: 1100px;
    }
  }
</style>