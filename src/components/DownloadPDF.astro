---
// src/components/DownloadPDF.astro
interface Props { destination: Record<string, any>; }
const { destination } = Astro.props;
---
<button
  id="btn-download-pdf"
  data-dest={JSON.stringify(destination)}
  class="inline-flex items-center gap-2 bg-[#0C005F] hover:bg-blue-900 active:scale-95 text-white font-semibold text-sm py-3 px-5 rounded-lg shadow transition-all duration-150"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h4a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
  </svg>
  <span id="pdf-btn-label">Descargar PDF</span>
  <svg id="pdf-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
  </svg>
</button>

<script>
  // @ts-nocheck
  document.addEventListener('DOMContentLoaded', () => {
    const btn     = document.getElementById('btn-download-pdf');
    const label   = document.getElementById('pdf-btn-label');
    const spinner = document.getElementById('pdf-spinner');
    if (!btn) return;

    btn.addEventListener('click', async () => {
      btn.disabled = true;
      label.textContent = 'Generando...';
      spinner.classList.remove('hidden');
      try {
        const destination = JSON.parse(btn.dataset.dest || '{}');
        const res = await fetch('/.netlify/functions/generate-pdf', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ destination }),
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const blob = await res.blob();
        const url  = URL.createObjectURL(blob);
        const a    = document.createElement('a');
        a.href     = url;
        a.download = `${(destination.name||'destino').replace(/[^a-z0-9]/gi,'-').toLowerCase()}-itinerario.pdf`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
      } catch (err) {
        console.error('PDF error:', err);
        alert('No se pudo generar el PDF. Intenta de nuevo.');
      } finally {
        btn.disabled = false;
        label.textContent = 'Descargar PDF';
        spinner.classList.add('hidden');
      }
    });
  });
</script>