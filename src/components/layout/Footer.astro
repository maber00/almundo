---
import { Image } from 'astro:assets';
import logo from '../../assets/images/Logo3blanco.webp';
import { Icon } from 'astro-icon/components';

// Importa las imágenes para Efecty y Baloto

// Enlaces rápidos, destinos y demás arrays siguen igual…
const quickLinks = [
  { label: "Destinos Nacionales", url: "/destinos/nacionales" },
  { label: "Destinos Internacionales", url: "/destinos/internacionales" },
  { label: "Promociones", url: "/promociones" },
  { label: "Blog de Viajes", url: "/blog" },
];

const popularDestinations = [
  { label: "Amazonas", url: "/destinos/nacionales/amazonas" },
  { label: "San Andrés", url: "/destinos/nacionales/san-andres" },
  { label: "Perú", url: "/destinos/internacionales/peru" },
  { label: "La Guajira", url: "/destinos/nacionales/la-guajira" },
];

const legalLinks = [
  { label: "Términos y Condiciones", url: "/terminos-condiciones" },
  { label: "Política de Privacidad", url: "/politica-privacidad" },
  { label: "Política de Cancelación", url: "/politica-cancelacion" },
];

// Redes sociales se mantienen con Iconify
const socialMedia = [
  { name: "Instagram", url: "https://www.instagram.com/al_mundotours", icon: "tabler:brand-instagram" },
  { name: "TikTok", url: "https://www.tiktok.com/@al.mundo.tours", icon: "tabler:brand-tiktok" },
  { name: "WhatsApp", url: "https://wa.me/573165276338", icon: "tabler:brand-whatsapp" },
  { name: "Facebook", url: "https://www.facebook.com/p/Al-Mundo-Tours-61565786490036/", icon: "tabler:brand-facebook" },
];

// Métodos de pago: para Efecty y Baloto se usan las imágenes en lugar de iconos
const paymentMethods = [
  { icon: "simple-icons:visa" },
  { icon: "simple-icons:mastercard" },
  { icon: "simple-icons:americanexpress" },
  { icon: "tabler:building-bank" } // PSE
];
---

<footer class="bg-[#0C005F] text-white pt-16 pb-8">
  <!-- Recuerda incluir el script de Iconify en el layout o en la página principal -->
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
      <!-- Columna 1: Información de contacto -->
      <div>
        <div class="mb-6">
          <Image src={logo} alt="Almundo Tour" width={160} height={120}  />
        </div>
        <p class="text-gray-400 mb-4">
          Agencia de viajes en Colombia con experiencia internacional. RNT: 218706.
        </p>
        <div class="space-y-3 text-sm text-gray-300">
          <p>📍 Calle 38 No 21-31<br/>Tuluá, Colombia</p>
          <p>📱 +57 316 527 6338</p>
          <p>✉️ info@almundotours.com</p>
          <p>⏰ Lun - Vie: 8:00 AM - 6:00 PM<br/>Sábados: 9:00 AM - 1:00 PM</p>
        </div>
      </div>

      <!-- Columna 2: Enlaces rápidos -->
      <div>
        <h3 class="text-xl font-bold mb-6 text-white">Enlaces Rápidos</h3>
        <ul class="space-y-3">
          {quickLinks.map((link) => (
            <li>
              <a href={link.url} class="text-gray-400 hover:text-blue-400 transition-colors flex items-center">
                ➡️ {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Columna 3: Destinos populares -->
      <div>
        <h3 class="text-xl font-bold mb-6 text-white">Destinos Populares</h3>
        <ul class="space-y-3">
          {popularDestinations.map((destination) => (
            <li>
              <a href={destination.url} class="text-gray-400 hover:text-blue-400 transition-colors flex items-center">
                ➡️ {destination.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Columna 4: Newsletter y redes -->
      <div>
        <h3 class="text-xl font-bold mb-6 text-white">Suscríbete a nuestras ofertas</h3>
        <p class="text-gray-400 mb-4">
          Recibe nuestras mejores ofertas y promociones directamente en tu correo.
        </p>
        <form id="newsletter-form" class="mb-6" name="newsletter" method="POST" data-netlify="true" netlify-honeypot="bot-field">
          <input type="hidden" name="form-name" value="newsletter" />
          <p class="hidden">
            <label>No llenes esto si eres humano: <input name="bot-field" /></label>
          </p>
        
          <div class="flex">
            <input 
              type="email" 
              id="newsletter-email"
              name="email" 
              placeholder="Tu correo electrónico" 
              class="bg-gray-800 text-white px-4 py-2 rounded-l-md w-full focus:outline-none focus:ring-2 focus:ring-blue-500"
              required
            />
            <button 
              type="submit" 
              class="bg-[#0C005F] text-white px-4 py-2 rounded-r-md hover:bg-blue-700 transition-colors"
            >
              ✉️
            </button>
          </div>
        
          <div id="newsletter-status" class="mt-2 text-sm text-center hidden">
            <p id="newsletter-success" class="text-green-400 hidden">✅ ¡Gracias por suscribirte!</p>
            <p id="newsletter-error" class="text-red-400 hidden">⚠️ Ha ocurrido un error. Inténtalo de nuevo.</p>
          </div>
        </form>
        <h4 class="text-lg font-bold mb-4 text-white">Síguenos</h4>
<div class="flex space-x-4">
  {socialMedia.map((social) => (
    <a 
      href={social.url} 
      target="_blank" 
      rel="noopener noreferrer"
      aria-label={`Síguenos en ${social.name}`}
      class="hover:text-blue-400 transition-colors"
    >
<Icon name={social.icon} class="w-6 h-6" />    </a>
  ))}
</div>
      </div>
    </div>

    <!-- Métodos de pago -->
    <div class="border-t border-gray-800 pt-8 mb-8">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <div class="mb-4 md:mb-0">
          <h4 class="text-lg font-bold mb-3 text-white">Métodos de pago aceptados</h4>
          <div class="flex flex-wrap gap-6 items-center">
  {paymentMethods.map((method) => (
    <div class="opacity-80 hover:opacity-100 transition-opacity">
      <Icon 
        name={method.icon} 
        class="w-8 h-8 text-white"
      />
    </div>
  ))}
</div>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-gray-800 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <p class="text-gray-500 text-sm mb-4 md:mb-0">
          &copy; {new Date().getFullYear()} AL mundo Tours. Todos los derechos reservados.
        </p>
        <div class="flex flex-wrap justify-center space-x-4">
          {legalLinks.map((link) => (
            <a href={link.url} class="text-gray-500 hover:text-blue-400 text-sm transition-colors">
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</footer>

<script>
  // @ts-nocheck
  document.addEventListener('DOMContentLoaded', function() {
    var form      = document.getElementById('newsletter-form');
    var statusBox = document.getElementById('newsletter-status');
    var success   = document.getElementById('newsletter-success');
    var errorEl   = document.getElementById('newsletter-error');

    if (!form) return;

    form.addEventListener('submit', function(e) {
      e.preventDefault();

      // 1) Recoger email
      var fd = new FormData(form);
      var email = fd.get('email');

      // 2) Backup en Netlify Forms
      fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(fd).toString()
      }).catch(function(){/* no bloquea si falla */});

      // 3) Enviar a Airtable vía nuestra Function
      fetch('/.netlify/functions/submit-subscription', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email })
      })
      .then(function(res) {
        return res.json().then(function(json) {
          return { status: res.status, body: json };
        });
      })
      .then(function(result) {
        statusBox.classList.remove('hidden');
        if (result.status >= 200 && result.status < 300 && result.body.success) {
          success.classList.remove('hidden');
          errorEl.classList.add('hidden');
          form.reset();
        } else {
          throw new Error(result.body.message || 'Error inesperado');
        }
      })
      .catch(function(err) {
        console.error('Error suscrip:', err);
        statusBox.classList.remove('hidden');
        success.classList.add('hidden');
        errorEl.classList.remove('hidden');
      });
    });
  });
</script>

